{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-native",
    "lib": ["es2017"],
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "strict": true,
    "target": "esnext",
    "baseUrl": "src",
    "paths": {
      "@assets/*": ["assets/*"],
      "@components/*": ["components/*"],
      "@loader/*": ["components/ContentLoader/*"],
      "@config/*": ["config/*"],
      "@navigation/*": ["navigation/*"],
      "@services/*": ["services/*"],
      "@theme/*": ["theme/*"],
      "@utils/*": ["utils/*"],
      "@views/*": ["views/*"],
      "@redux/*": ["redux/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ]
}
